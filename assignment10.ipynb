   "source": [
    "#1) Replace Nan with 0 and Interchange 3 rows and 3 columns of 2D array [[6, -8, 73, -110], [np.nan, -8, 0, 94]]\n",
    "import numpy as np\n",
    "\n",
    "a=np.array([[6, -8, 73, -110],\n",
    "            [np.nan, -8, 0, 94],\n",
    "            [1,2,3,4],\n",
    "            [5,6,7,8]])\n",
    "\n",
    "print(\"Original Array:\")\n",
    "print(a)\n",
    "\n",
    "a[[0,1,2],:] = a[[2,0,1],:]\n",
    "print(\"\\nAfter Row Interchange:\")\n",
    "print(a)\n",
    "\n",
    "a[:,[0,1,2]] = a[:,[2,0,1]]\n",
    "print(\"\\nAfter Column Interchange:\")\n",
    "print(a)"
   ]
  }
