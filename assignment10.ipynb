    "# 2) Move axes of 3D array to new positions\n",
    "import numpy as np\n",
    "\n",
    "a=np.array([[6, -8, 73, -110],\n",
    "            [np.nan, -8, 0, 94],\n",
    "            [1,2,3,4],\n",
    "            [5,6,7,8]])\n",
    "\n",
    "print(\"Original Array:\")\n",
    "print(a)\n",
    "b=np.moveaxis(a,0,1)\n",
    "print(\"after moving axis\",b)"
   ]
  },
