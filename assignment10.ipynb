   "source": [
    "#33) Replace NaN values with average of columns\n",
    "import numpy as np\n",
    "arr=np.array([[6, -8, 73, -110], [np.nan, -8, 0, 94]]) \n",
    "avg=6\n",
    "arr2=np.nan_to_num(arr,nan=avg)\n",
    "print(arr2) "

    import numpy as np

a = np.array([[6, -8, 73, -110],
              [4, -8, 0, 94],
              [1, 2, 3, 4],
              [5, 6, 7, 8]])

for i in range(a.shape[0]):
    for j in range(a.shape[1]):
        if a[i, j] < 0:
            a[i, j] = 0

print(a)
   ]
